# Copy to apps/api/.env.local

# Required
DATABASE_URL="postgresql://user:pass@host:5432/flowforge?sslmode=require"
JWT_SECRET="change-me-to-a-long-random-string"
# Public API origin for QStash callbacks (production). Local worker ignores this
# in next dev and always uses http://localhost:PORT so DB + worker stay in sync.
APP_URL="http://localhost:3001"
# Optional override for local worker base URL
# LOCAL_APP_URL="http://localhost:3001"

# QStash (cron schedules) — from https://console.upstash.com/qstash
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# Email (optional — Send Email action runs in demo mode without it)
RESEND_API_KEY=""

# Optional: protect POST /api/worker (when set, hooks/cron/forms auto-send it)
# Leave empty for local open mode (backward compatible).
WORKER_SECRET=""

# Optional integrations
NOTION_API_KEY=""
TRELLO_API_KEY=""
TRELLO_API_TOKEN=""

# Google OAuth (login + Sheets connection)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/oauth/google/callback"

# GitHub OAuth (login)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
